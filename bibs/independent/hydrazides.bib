
@article{amundson_pyromellitic_2026,
	title = {Pyromellitic dihydrazides as hydrolytically stable analogs of pyromellitic diimide},
	volume = {24},
	issn = {1477-0520, 1477-0539},
	url = {https://xlink.rsc.org/?DOI=D6OB00281A},
	doi = {10.1039/D6OB00281A},
	abstract = {Pyromellitic dihydrazide is a significant upgrade to pyromellitic diimides, combining ease-of-synthesis, extreme alkaline stability, and thermal and structural features together into a new scaffold that is attractive for robust materials.
          , 
            The utility of aromatic diimides in materials can be compromised by their instability toward nucleophiles such as water. Here, we present pyromellitic dihydrazides (PMDHs) as a robust alternative that retains the favorable optoelectronic and thermal properties of the parent imides while eliminating their hydrolytic weakness. These solution-processible compounds feature reversible electrochemistry and withstand high temperatures, yet remain chemically inert under harsh alkaline conditions that degrade standard cyclic imides. These findings introduce the cyclic hydrazide motif as a versatile, superior building block of potential interest to researchers engineering robust functional materials.},
	language = {en},
	number = {13},
	urldate = {2026-04-01},
	journal = {Org. Biomol. Chem.},
	author = {Amundson, Journey M. and Brush, Ryan B. and Jensen, Kara M. and Funk, Baela R. and Jung, Healeam and Mamicha, Sam K. and Young, Victor G. and Garcia L., Eryck and Klivansky, Liana M. and Cao, Dennis D.},
	year = {2026},
	pages = {2650--2654},
	file = {PDF:C\:\\Users\\dcao\\Zotero\\storage\\SMJZIW59\\Amundson et al. - 2026 - Pyromellitic dihydrazides as hydrolytically stable analogs of pyromellitic diimide.pdf:application/pdf},
